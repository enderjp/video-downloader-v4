# Copia este archivo a .env y ajusta los valores segun tu despliegue
PORT=3000
PUPPETEER_HEADLESS=new
PUPPETEER_TIMEOUT=60000
FACEBOOK_LOCALE=en-US,en;q=0.9
BLOCK_HEAVY_ASSETS=true
PUPPETEER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36
FACEBOOK_COOKIES_PATH=./cookies-feb-2026.txt
FACEBOOK_DEBUG_SNAPSHOTS=true
FACEBOOK_DEBUG_DIR=./snapshots
